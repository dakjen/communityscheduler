# Neon PostgreSQL Database
DATABASE_URL=
# Example: postgresql://user:password@ep-cold-mud-12345.us-east-2.aws.neon.tech/dbname?sslmode=require

# Clerk Authentication Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# JWT Secret for Admin Sessions (generate a strong random string)
JWT_SECRET_KEY=your_super_secret_jwt_key_here

# Brevo transactional email (https://app.brevo.com → SMTP & API → API Keys)
BREVO_API_KEY=
# From/reply addresses — must be a verified sender/domain in Brevo
BREVO_FROM_EMAIL=noreply@ninetyfourten.com
BREVO_REPLY_TO_EMAIL=noreply@ninetyfourten.com
# Public site URL used in email links
NEXT_PUBLIC_SITE_URL=https://booking.ninetyfourten.com